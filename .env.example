DATABASE_URL=sqlite:///./.data/websmith.sqlite3
BACKEND_CORS_ORIGINS=http://localhost:5173

# Required for enrichment summaries, outreach drafts, reply drafts, and
# website handoff brief generation.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Current documented default choices:
# - gpt-5.4-mini: strong cost-efficient default for enrichment, outreach, and JSON summaries.
# - gpt-5.4 / gpt-5.5: stronger fallbacks for harder reasoning/copy tasks.
# - gpt-image-2: current GPT Image default for generated website assets.
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BACKUP_MODELS=gpt-5.4,gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_BACKUP_MODELS=gpt-image-1.5

OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
ALLOW_DEMO_RESULTS=false
